# Discord bot credentials — get these from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here

# Backend API URL (must be running before starting the bot)
BACKEND_URL=http://localhost:4000

# Channel ID where the bot posts proactive alerts (optional)
ALERT_CHANNEL_ID=your_channel_id_here

# (Optional) Anthropic API key for LLM-powered conversational responses
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
